<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Roadbook" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/rally_white</item>
        <item name="android:statusBarColor">@color/rally_white</item>
        <item name="android:navigationBarColor">@color/rally_white</item>
        <item name="android:windowAnimationStyle">@null</item>
